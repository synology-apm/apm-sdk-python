# APM CLI / SDK test environment configuration
# Copy to .env and fill in real values (.env is already in .gitignore — never commit it)

# APM hostname or IP; supports host:port format; SDK automatically prepends https://
APM_HOST=apm.corp.com
# APM_HOST=apm.corp.com:10443  # use this format for a custom port

APM_USERNAME=admin
APM_PASSWORD=

# Set to true for self-signed certificate environments; omit or set to false for production
APM_NO_VERIFY_SSL=true

# Config profile to use (optional, defaults to "default")
# APM_PROFILE=default
